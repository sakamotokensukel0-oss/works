#!/usr/bin/env python3

import os
import glob
import bisect

from cyvcf2 import VCF

VCF_PATH = "/home/sakamoto/work/partial_data_WRC_JRC/chr01_WRC_JRC.vcf.gz"

MAF_DIR = "/home/sakamoto/work/partial_data_WRC_JRC/2026/lift_over/maf/osat_irgsp-1.0.v.obar_o.barthii_v1.lastz_net"

OUT_TSV_PATH = "/home/sakamoto/work/partial_data_WRC_JRC/2026/lift_over/chr01_japonica_sites_barthii_base.tsv"

SATIVA_CHR_ID = "1"

SATIVA_SOURCE = f"oryza_sativa.{SATIVA_CHR_ID}"

OUTGROUP_PREFIX = "oryza_barthii."

OUTGROUP_LABEL = "barthii"

COMPLEMENT_TABLE = str.maketrans("ACGTNacgtn", "TGCANtgcan")


# アライメントのmaf_pos番目の塩基をフォワード鎖の塩基として返す
def get_base(record, maf_pos):
    base = record["aligned_seq"][maf_pos]

    # - strandは逆相補鎖なので変換する
    if record["strand"] == "-":
        return base.translate(COMPLEMENT_TABLE).upper()

    return base.upper()

#mafブロック単位でブロックに含まれるvcf上のサイトのposでのoutgroupのbaseを調べ書き込む
def process_maf_block(
    maf_block_lines,
    maf_path,
    vcf_dict,
    sorted_vcf_pos,
    out_tsv_fh,
    matched_vcf_site_ids,
    ):

    # s 行をわけてリストにする 
    maf_s_lines = []
    for line in maf_block_lines:
        if not line.startswith("s "):
            continue
        #スペースで区切って各要素を辞書に格納、辞書をリストに格納
        fields = line.split()
        maf_s_lines.append({
            "source": fields[1],
            "maf_start": int(fields[2]),
            "aligned_base_count": int(fields[3]),
            "strand": fields[4],
            "source_size": int(fields[5]),
            "aligned_seq": fields[6],
        })

    if not maf_s_lines:
        return

    #辞書の辞書を作成
    record_by_source = {}
    for record in maf_s_lines:
        #keyはrecordのsource, valueは前に作った辞書
        record_by_source[record["source"]] = record

    #sativaの方のrecordを取り出す
    sativa_record = record_by_source[SATIVA_SOURCE]

    # スコアの取り出し
    maf_score = "."
    for line in maf_block_lines:
        for item in line.split():
            if item.startswith("score="):
                maf_score = item.replace("score=", "")#数値以外の部分を消去
                break
        if maf_score != ".":
            break

    # sativaブロックのフォワード座標区間、block_startとblock_endは両方closed
    if sativa_record["strand"] == "+":
        sativa_block_start = sativa_record["maf_start"]

        #aligned_base_countはgapを除外した塩基数
        sativa_block_end = sativa_record["maf_start"] + sativa_record["aligned_base_count"] - 1
    
    # - ストランドの場合
    else:
        sativa_block_start = (
            sativa_record["source_size"]
            - sativa_record["maf_start"]
            - sativa_record["aligned_base_count"]
        )
        sativa_block_end = sativa_block_start + sativa_record["aligned_base_count"] - 1

    #sorted_vcf_posにstartを挿入した場合、startの値がリストの何番目(0based)かを返す
    #完全一致するものがsorted_vcf_posにあった場合leftにいれる
    first_vcf_index = bisect.bisect_left(
        sorted_vcf_pos,
        sativa_block_start,
    )

    #sorted_vcf_posにendを挿入した場合、endの値がリストの何番目(0based)かを返す
    #完全一致するものがsorted_vcf_posにあった場合rightにいれる 
    past_last_vcf_index = bisect.bisect_right(
        sorted_vcf_pos,
        sativa_block_end,
    )

    #poslistで重なっている部分を抽出
    vcf_positions_in_block = sorted_vcf_pos[
        first_vcf_index:past_last_vcf_index#cloes:openで抽出
    ]

    if not vcf_positions_in_block:
        return

    vcf_position_set_in_block = set(vcf_positions_in_block)

    # key = sativa_pos, value = mafブロックで左から何番目か（gapを含んで）
    sativa_pos_to_maf_pos = {}
    base_index_without_gap = 0
    for maf_pos, base in enumerate(sativa_record["aligned_seq"]):
        if base == "-":
            continue

        #現在のmaf上の位置をsativa_posに換算
        if sativa_record["strand"] == "+":
            sativa_pos = sativa_record["maf_start"] + base_index_without_gap
        else:
            sativa_pos = (
                sativa_record["source_size"]
                - 1
                - (sativa_record["maf_start"] + base_index_without_gap)
            )

        if sativa_pos in vcf_position_set_in_block:
            sativa_pos_to_maf_pos[sativa_pos] = maf_pos

        base_index_without_gap += 1

    # outgroupレコード (barthiiは1ブロックに1つ前提なので最初の1件を使う)
    outgroup_record = None
    for record in maf_s_lines:
        if record["source"].startswith(OUTGROUP_PREFIX):
            outgroup_record = record
            break

    # barthiiの行がなければこのブロックはスキップ
    if outgroup_record is None:
        return

    # outgroupの染色体名取り出し 
    outgroup_chr = outgroup_record["source"].replace(OUTGROUP_PREFIX, "", 1)

    # 各VCFサイトを処理
    for sativa_pos, maf_pos in sativa_pos_to_maf_pos.items():

        #sativaに関してその位置の塩基を取得する
        sativa_base_in_maf = get_base(
            sativa_record,
            maf_pos,
        )

        #outgroupに関してその位置の塩基を取得する
        outgroup_forward_base = get_base(
            outgroup_record,
            maf_pos,
        )

        if outgroup_forward_base == "-":
            mapping_status = f"gap_in_{OUTGROUP_LABEL}"
        else:
            mapping_status = "mapped"

        vcf_site = vcf_dict[sativa_pos]#該当サイトのvcfの情報を取り出す
        matched_vcf_site_ids.add(vcf_site["site_id"])#マッチできたsiteのidを記録

        out_tsv_fh.write(
            "\t".join(map(str, [
                vcf_site["chrom"],
                vcf_site["pos"],
                vcf_site["ref"],
                vcf_site["alt"],
                sativa_base_in_maf,
                outgroup_record["source"],
                outgroup_chr,
                outgroup_record["strand"],
                outgroup_forward_base,
                mapping_status,
                maf_score,
                os.path.basename(maf_path),
                maf_pos,
            ])) + "\n"
        )

#vcfの情報やmafの情報を扱いやすい形に整理しdef process_maf_blockに渡す
#最終的にマッチしなかったサイトを書き込む
def main():
    # VCF処理 
    vcf_dict = {}#posがキーの辞書を作成
    sorted_vcf_pos = []#posの降順のリストを作成
    vcf_site_id = 0

    #vcfのサイトごとの処理
    for variant in VCF(VCF_PATH):
        vcf_chrom = variant.CHROM
        vcf_pos = variant.POS
        vcf_ref = variant.REF
        vcf_alt = variant.ALT[0] #bialleic siteに興味があるのでALT[0]に限定している

        #mafは0based, vcfは1basedなのでmafようの座標に変換する
        sativa_pos = vcf_pos - 1
        vcf_site_id += 1

        vcf_site = {
            "site_id": vcf_site_id,
            "chrom": vcf_chrom,
            "pos": vcf_pos, #vcfに入っている1based
            "sativa_pos": sativa_pos,
            "ref": vcf_ref,
            "alt": vcf_alt,
        }

        #辞書にそのposのキーでサイトを登録 (重複なし前提なので直接代入)
        vcf_dict[sativa_pos] = vcf_site

        #posのリストにも追加
        sorted_vcf_pos.append(sativa_pos)

    #全てのsiteを走査したら、posのリストをソートする
    sorted_vcf_pos.sort()




    # MAFファイルを処理

    #処理を行う対象のファイル名のパターンを指定
    maf_pattern = os.path.join(
        MAF_DIR,
        f"*.lastz_net.{SATIVA_CHR_ID}_*.maf",
    )

    #maf_patternに当てはまるようなファイル名のファイルをソートされたリストにする
    maf_paths = sorted(glob.glob(maf_pattern))

    #mafとvcfで対応するものがあったサイトのidを記録
    matched_vcf_site_ids = set()

    #ヘッダー作成
    with open(OUT_TSV_PATH, "w") as out_tsv_fh:
        out_tsv_fh.write(
            "\t".join([
                "sativa_chr",
                "sativa_pos",
                "vcf_ref",
                "vcf_alt",
                "maf_sativa_base",
                f"{OUTGROUP_LABEL}_source",
                f"{OUTGROUP_LABEL}_chr",
                f"{OUTGROUP_LABEL}_strand",
                f"{OUTGROUP_LABEL}_base",
                "status",
                "maf_score",
                "maf_file",
                "maf_pos",
            ]) + "\n"
        )

        #maf_pathファイルごとの操作
        for maf_path in maf_paths:

            #ファイル内のmaf blockをリストとして入れる
            maf_block_lines = []

            with open(maf_path, "r") as fh:
                #前提：扱っているmafファイルの最初のlineは空行でなく、最後のlineは必ず空行
                for line in fh:

                    if line.strip() != "":
                        maf_block_lines.append(line)
                    #その行が空行(mafブロックの境界)だった場合に行う。
                    else:
                        process_maf_block(
                            maf_block_lines,
                            maf_path,
                            vcf_dict,
                            sorted_vcf_pos,
                            out_tsv_fh,
                            matched_vcf_site_ids,
                        )
                        maf_block_lines = []#１ブロックに対しての処理が終わったらlistを空にする

        # マッチしなかったVCFサイトを出力
        for sativa_pos in sorted_vcf_pos:
            vcf_site = vcf_dict[sativa_pos]
            if vcf_site["site_id"] not in matched_vcf_site_ids:
                out_tsv_fh.write(
                    "\t".join(map(str, [
                        vcf_site["chrom"],
                        vcf_site["pos"],
                        vcf_site["ref"],
                        vcf_site["alt"],
                        ".",
                        ".",
                        ".",
                        ".",
                        ".",
                        "no_maf_block",
                        ".",
                        ".",
                        ".",
                    ])) + "\n"
                )

    print("out_tsv:", OUT_TSV_PATH)


if __name__ == "__main__":
    main()